{
  "name": "@legionforge/mcp-probe",
  "version": "0.1.0",
  "description": "Connectivity and configuration advisor for MCP services you own or operate. Configures, connects, diagnoses, and recommends — no network scanning or unauthorized probing.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "diagnostic",
    "configuration"
  ],
  "author": "JP Cruz <jp@legionforge.org>",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/legionforge/mcp-probe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legionforge/mcp-probe.git"
  },
  "type": "module",
  "bin": {
    "mcp-probe": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && cp -r src/ui/public dist/",
    "dev": "tsx src/cli.ts",
    "probe": "tsx src/cli.ts probe",
    "audit": "tsx src/cli.ts audit",
    "ui": "tsx src/cli.ts ui",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "tsup": {
    "entry": [
      "src/cli.ts",
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node20",
    "splitting": false,
    "sourcemap": false,
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}
